# Nexus-OS: Environment Variables (Example)

# Database
DB_NAME=nexus
DB_USER=nexus_user
DB_PASSWORD=changeme
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=changeme

# Authentication
JWT_SECRET=your_long_randomly_generated_secret_key_here
JWT_EXPIRY_MS=86400000

# Backend Alerts (Gmail SMTP)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Storage
UPLOAD_DIR=/uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
